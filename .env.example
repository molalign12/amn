<?php
/**
 * .env.example - Copy to .env and fill in your values
 */

APP_ENV=development
APP_URL=http://localhost/amnen

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=amnen_hotel
DB_PORT=3306

# Fayda ID Integration
FAYDA_ID_ENABLED=true
FAYDA_ID_API_KEY=your_fayda_id_api_key_here
FAYDA_ID_API_URL=https://api.fayda.id/v1
FAYDA_ID_WEBHOOK_SECRET=your_webhook_secret_here

# Chapa Payment
CHAPA_ENABLED=true
CHAPA_PUBLIC_KEY=your_chapa_public_key
CHAPA_SECRET_KEY=your_chapa_secret_key
CHAPA_API_URL=https://api.chapa.co/v1

# Session
SESSION_LIFETIME=86400

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Cron Security
CRON_SECRET_KEY=your-cron-secret-key

# Features
AUTO_CHECKIN_ENABLED=true
AUTO_CHECKOUT_ENABLED=true
CLEANUP_CRON_ENABLED=true
ACCESSIBILITY_ENABLED=true
